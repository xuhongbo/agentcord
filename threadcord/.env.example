# Discord Bot
DISCORD_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=your-client-id-here
DISCORD_GUILD_ID=your-guild-id-here   # optional, for faster slash command registration

# Access Control
ALLOWED_USER_IDS=123456789,987654321  # comma-separated Discord user IDs
ALLOW_ALL_USERS=false                  # set true to allow everyone

# Filesystem
DEFAULT_DIRECTORY=~                    # default working directory for new sessions
ALLOWED_PATHS=~                        # comma-separated allowed roots
DATA_DIR=~/.threadcord                 # where to store sessions/projects JSON

# Provider Defaults
DEFAULT_PROVIDER=claude                # claude | codex
DEFAULT_MODE=auto                      # auto | plan | normal | monitor

# Subagent Limits
MAX_SUBAGENT_DEPTH=3                   # max chain depth to prevent infinite loops

# Codex Provider (optional)
CODEX_SANDBOX_MODE=workspace           # workspace | project | none
CODEX_APPROVAL_POLICY=auto-edit        # auto-edit | on-failure | never
CODEX_NETWORK_ACCESS=false

# Message Cleanup (optional)
MESSAGE_RETENTION_DAYS=0               # 0 = disabled
RATE_LIMIT_MS=1000
