# Discord Bot
DISCORD_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=your-client-id-here
DISCORD_GUILD_ID=your-guild-id-here   # optional, for faster slash command registration

# Access Control
ALLOWED_USER_IDS=123456789,987654321  # comma-separated Discord user IDs
ALLOW_ALL_USERS=false                  # set true to allow everyone

# Filesystem
DEFAULT_DIRECTORY=~                    # default working directory for new sessions
ALLOWED_PATHS=~                        # comma-separated allowed roots
DATA_DIR=~/.threadcord                 # where to store sessions/projects JSON

# Provider Defaults
DEFAULT_PROVIDER=claude                # claude | codex
DEFAULT_MODE=auto                      # auto | plan | normal | monitor

# Claude API proxy (optional — claude provider reads these from env automatically)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# Subagent Limits
MAX_SUBAGENT_DEPTH=3                   # max chain depth to prevent infinite loops

# Auto-archive
MAX_ACTIVE_SESSIONS=20                 # archive oldest sessions when exceeded
AUTO_ARCHIVE_DAYS=7                    # archive sessions inactive for N days

# Codex Provider (optional)
# CODEX_API_KEY=sk-...                 # OpenAI API key (or compatible key for proxy)
# CODEX_BASE_URL=https://...           # OpenAI-compatible API base URL (for proxy)
CODEX_SANDBOX_MODE=workspace-write     # read-only | workspace-write | danger-full-access
CODEX_APPROVAL_POLICY=on-failure       # never | on-request | on-failure | untrusted
CODEX_NETWORK_ACCESS=false
CODEX_WEB_SEARCH=disabled              # disabled | cached | live
CODEX_REASONING_EFFORT=               # minimal | low | medium | high | xhigh

# Message Cleanup (optional)
MESSAGE_RETENTION_DAYS=0               # 0 = disabled
RATE_LIMIT_MS=1000
