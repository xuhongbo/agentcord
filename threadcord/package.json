{
  "name": "threadcord",
  "version": "0.1.0",
  "description": "Discord bot for multi-agent AI coding sessions — Channel=Project, Thread=Agent",
  "type": "module",
  "bin": {
    "threadcord": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --onSuccess 'touch dist/.restart'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.84",
    "@clack/prompts": "^1.0.0",
    "discord.js": "^14.16.3",
    "dotenv": "^17.2.4",
    "sharp": "^0.34.5"
  },
  "optionalDependencies": {
    "@openai/codex-sdk": "^0.116.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.6.0"
  },
  "license": "MIT"
}
