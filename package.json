{
  "name": "agentcord",
  "version": "2.1.1",
  "description": "Discord bot for managing AI coding agent sessions",
  "type": "module",
  "bin": {
    "agentcord": "./bin/agentcord.js"
  },
  "scripts": {
    "build": "tsup",
    "start": "node --experimental-strip-types src/cli.ts",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.84",
    "@clack/prompts": "^1.1.0",
    "configstore": "^7.0.0",
    "discord.js": "^14.25.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/configstore": "^6.0.0",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "optionalDependencies": {
    "@openai/codex-sdk": "^0.116.0"
  },
  "engines": {
    "node": ">=22.6.0"
  }
}
